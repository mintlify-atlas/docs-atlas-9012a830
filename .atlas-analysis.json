  "keyFeatures": [
    "Direct S3 uploads via pre-signed URLs",
    "Asynchronous processing with BullMQ + Redis workers",
    "Audio format conversion (MP3/AAC) using FFmpeg",
    "Metadata extraction from audio/video files",
    "Waveform generation stored as JSON",
    "Parallel video processing (mute video + audio extraction)",
    "User authentication with JWT",
    "MongoDB database with Prisma ORM"
  ],
